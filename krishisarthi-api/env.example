# KishanSaathi Backend — .env.example
# Copy to .env and fill in real values before running.

# ── PostgreSQL (Neon) ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ── Agromonitoring API  ───────────────────────────────────────────────────────
AGRO_API_KEY=your_agromonitoring_key_here
AGROMONITORING_API_KEY=your_agromonitoring_key_here

# ── ML Model directory ────────────────────────────────────────────────────────
# ── APMC Mandi API (data.gov.in) ──────────────────────────────────────────────
APMC_MANDI_API_KEY=your_apmc_mandi_api_key_here

# ── ML Model artifacts directory (default: Encoder_and_model/) ───────────────
MODEL_DIR=Encoder_and_model

# ── CSV Migration path ────────────────────────────────────────────────────────
CSV_PATH=Dataset/KrishiTwin_Final_Engineered.csv

# ── Chatbot: Groq LLM ─────────────────────────────────────────────────────────
GROK_API_KEY=your_groq_api_key_here

# ── LangSmith tracing ─────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=AgriSage-Chatbot

# ── Google OAuth (Option B) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_BASE_URL=http://localhost:5173

# ── Agmarknet (crop mandi prices) ─────────────────────────────────────────────
AGMARKNET_API_KEY=your_agmarknet_key_here

# ── Mandi master JSON path ────────────────────────────────────────────────────
MANDI_JSON_PATH="./data/mandi_master (1).json"
